local function setRing(ring, waitTime)
	if ring then
		if current then
			--current:FindFirstChild("GuiHolder").BillboardGui.Enabled = false
		end
		
		current = ring

		local Difficulties = current:WaitForChild("TowerDifs")

		--NavGui.MainFrame.InfoDetail.InfoBox.Text = current:WaitForChild("Info").Value
		--NavGui.MainFrame.RingDetail.Ring.Text = current:WaitForChild("PlaceName").Value
		ts:Create(workspace.CurrentCamera,TweenInfo.new(waitTime or 1),{CFrame = ring.Cam.CFrame}):Play()
		
		ogCframe = ring.Cam.CFrame
		NavGui.MainFrame.RingName.Text = current:FindFirstChild("PlaceName").Value
		NavGui.MainFrame.InfoFrame.Requirement.Text = tostring(current:FindFirstChild("badgeCount").Value)
		NavGui.MainFrame.InfoFrame.Info.Text = current:FindFirstChild("Info").Value
		--current:FindFirstChild("GuiHolder").BillboardGui.Enabled = true
		
		for _, b in pairs(NavGui.MainFrame.TowerList.DifficultyBar:GetChildren()) do
			if b:IsA("Frame") then
				b:Destroy()
			end
		end
		
		for _, b in pairs(NavGui.MainFrame.TowerList.CompletionBar:GetChildren()) do
			if b:IsA("Frame") then
				b:Destroy()
			end
		end

		for i, tower in pairs(towerInfo) do
			if tower["Area"] == ring.PlaceName.Value then
				local difFrame = script.TowerItems:FindFirstChild(tower["Difficulty"]["Name"]):Clone()
				local completionFrame = script.TowerItems.Completion:Clone()
				
				difFrame.Parent = NavGui.MainFrame.TowerList.DifficultyBar
				difFrame.LayoutOrder = tower["Difficulty"]["Number"] * 100
				
				completionFrame.Parent = NavGui.MainFrame.TowerList.CompletionBar
				completionFrame.LayoutOrder = tower["Difficulty"]["Number"] * 100
				completionFrame.Name = i
				
				if (playerData["TowerCompletions"][i]["Wins"] > 0 or playerData["TowerCompletions"][i]["NoHitWins"] > 0) then
					completionFrame.BackgroundColor3 = Color3.fromRGB(133, 255, 133)
					completionFrame.UIStroke.Color = Color3.fromRGB(102, 255, 102)
				end
			end
		end
	end
end

local function setWorld(sworld)
	if sworld and worlddeb then
		worlddeb=false
		world=sworld
		--game.ReplicatedStorage.GuiTransitionLocal:FireServer()
		wait(2)
		if fogends[sworld.Name] then
			game.Lighting.FogEnd=fogends[sworld.Name]
		end
		--NavGui.WorldName.Image = sworld:WaitForChild("WorldName").Value
		--NavGui.MainFrame:WaitForChild'TowersBeaten'.Text=('Towers Completed: '..UniqueTowerCount[tonumber(string.sub(world.Name,2))])
		if sworld == workspace.RingSelect.W1 then
			worldString = "R"
			setRing(sworld:FindFirstChild'R1')
		elseif sworld == workspace.RingSelect.W2 then
			worldString = "Z"
			setRing(sworld:FindFirstChild'Z1')
		end
		workspace.CurrentCamera.CFrame=current.Cam.CFrame
		worlddeb=true
	end
end

