local ringSelectRarity
local ringSelectEvents
local rarityOpened = false

game.ReplicatedStorage.RNGEvents.OnClientEvent:Connect(function(rarity, events)
	ringSelectRarity = rarity
	ringSelectEvents = events
	
	if rarity == 1 then return end
	
	NavGui.MainFrame.RingSelectRarity.Visible = true
	
	local textLabel = NavGui.MainFrame.RingSelectRarity.Template:Clone()
	textLabel.Text = "Rarity 1 / " .. rarity
	textLabel.Name = "Rarity"
	textLabel.Visible = true
	textLabel.Parent = NavGui.MainFrame.RingSelectRarity
end)

NavGui.MainFrame.RingSelectRarity.MouseButton1Click:Connect(function()
	if ringSelectRarity == 1 or nil then return end
	
	if rarityOpened == false then
		rarityOpened = true
		
		NavGui.MainFrame.RingSelectRarity:FindFirstChild("Rarity"):Destroy()
		
		for i, v in pairs(ringSelectEvents) do
			local textLabel = NavGui.MainFrame.RingSelectRarity.Template:Clone()
			textLabel.Text = i .. " 1 / " .. v
			textLabel.Name = "Rarity"
			textLabel.LayoutOrder = v
			textLabel.Visible = true
			textLabel.Parent = NavGui.MainFrame.RingSelectRarity
		end
	else
		rarityOpened = false
		
		for i, child in pairs(NavGui.MainFrame.RingSelectRarity:GetChildren()) do
			if child.Name == "Rarity" then
				child:Destroy()
			end
		end
		
		local textLabel = NavGui.MainFrame.RingSelectRarity.Template:Clone()
		textLabel.Text = "Rarity 1 / " .. ringSelectRarity
		textLabel.Name = "Rarity"
		textLabel.Visible = true
		textLabel.Parent = NavGui.MainFrame.RingSelectRarity
	end
end)

