uis.InputBegan:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.Keyboard then
		if input.KeyCode == Enum.KeyCode.A or input.KeyCode == Enum.KeyCode.Left then
			NavGui.Swoosh:Play()
			local new = world:FindFirstChild(worldString..string.sub(current.Name,-1,-1)-1)
			if new then
				setRing(new)
			end
		elseif input.KeyCode == Enum.KeyCode.D or input.KeyCode == Enum.KeyCode.Right then
			NavGui.Swoosh:Play()
			local new = world:FindFirstChild(worldString..string.sub(current.Name,-1,-1)+1)
			if new then
				setRing(new)
			end
		elseif input.KeyCode == Enum.KeyCode.Return or input.KeyCode == Enum.KeyCode.Space then
			local wl={
				['Fwameys'] = true
			}
			if current and ((current.accessible.Value and badgeCount[tonumber(string.sub(world.Name,2))] >= current.badgeCount.Value) or wl[game.Players.LocalPlayer.Name]) or game.Players.LocalPlayer:GetRankInGroup(4406211) > 1 then
				NavGui.Enter:Play()
				game:GetService("TeleportService"):Teleport(current.placeId.Value)
			end
		end
	end
end)

uis.InputBegan:Connect(function(input)
